<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mobile App Summary"
            android:textColor="#061B3A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SmartStockSuite warehouse mobile scanner overview"
            android:textColor="#667085"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current User"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUserSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Logged in as: -"
                android:textColor="#0B5FFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Picking Tasks"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPickingSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Picking summary"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inventory Scanner"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInventorySummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inventory summary"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Traceability"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTraceabilitySummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Traceability summary"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Future Backend Integration"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFutureSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Future integration summary"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Back"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#667085"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>