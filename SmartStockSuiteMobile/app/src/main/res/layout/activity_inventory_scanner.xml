<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inventory Scanner"
            android:textColor="#061B3A"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan or manually enter product and location barcodes to verify stock and record movements."
            android:textColor="#667085"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Barcode"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProductBarcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product barcode: Not scanned yet"
                android:textColor="#0B5FFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnScanProductBarcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Scan Product Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#087443" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Or enter product barcode manually"
                android:textColor="#667085"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etProductBarcode"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Example: 7629184503716"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#061B3A"
                android:textColorHint="#98A2B3"
                android:background="#FFFFFF" />

            <Button
                android:id="@+id/btnCheckManualProductBarcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Check Product Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0B5FFF"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location Barcode"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLocationBarcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location barcode: Not scanned yet"
                android:textColor="#0B5FFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnScanLocationBarcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Scan Location Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#087443" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Or enter location barcode manually"
                android:textColor="#667085"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etLocationBarcode"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Example: LOC-A-02-04"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#061B3A"
                android:textColorHint="#98A2B3"
                android:background="#FFFFFF" />

            <Button
                android:id="@+id/btnCheckManualLocationBarcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Check Location Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0B5FFF"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/productDetailsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inventory Details"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product name: -"
                android:textColor="#061B3A"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvProductCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category: -"
                android:textColor="#667085"
                android:textSize="15sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvLocationDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location details: -"
                android:textColor="#667085"
                android:textSize="15sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvQuantityInLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quantity in location: -"
                android:textColor="#667085"
                android:textSize="15sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvStockStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock status: -"
                android:textColor="#087443"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvInventoryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Scan or enter product barcode, then scan or enter location barcode."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="18dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/movementCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Record Stock Movement"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSelectedMovementType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected movement type: -"
                android:textColor="#0B5FFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnMovementIn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Movement IN"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#087443" />

            <Button
                android:id="@+id/btnMovementOut"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Movement OUT"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B42318"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnMovementAdjustment"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Stock Adjustment"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D97706"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/etMovementAmount"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Enter quantity / new quantity"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#061B3A"
                android:textColorHint="#98A2B3"
                android:background="#FFFFFF"
                android:layout_marginTop="14dp" />

            <Button
                android:id="@+id/btnSaveMovement"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Stock Movement"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0B5FFF"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvMovementResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Movement result: Waiting for verified product and location"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="14dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Clear Scan"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#D97706"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Back"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#667085"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>