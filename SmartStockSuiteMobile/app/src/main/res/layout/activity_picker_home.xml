<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SmartStockSuite Mobile"
            android:textColor="#061B3A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="28dp" />

        <TextView
            android:id="@+id/tvHomeSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Warehouse mobile scanner dashboard"
            android:textColor="#667085"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:id="@+id/userCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome, Warehouse User"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmployeeInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Employee ID: Demo | Role: USER"
                android:textColor="#0B5FFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use this mobile app to complete picking tasks, verify product barcodes, check warehouse locations and record inventory movements."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPicking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Picking Tasks"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View assigned tasks, start picking, scan product barcode or enter it manually, then complete the task."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnPickingTasks"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Open Picking Tasks"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0B5FFF" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardInventory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inventory Scanner"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan product and location barcodes, check quantity in location and record stock movements."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnInventoryScanner"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Open Inventory Scanner"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#087443" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/summaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Project Demo Summary"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View a short summary of the mobile app features for the final project demonstration."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnMobileSummary"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="View Mobile App Summary"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D97706" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/recentActivityCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recent Mobile Activity"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecentActivityOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• No mobile activity recorded yet"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvRecentActivityTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Complete picking or inventory actions to see them here"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvRecentActivityThree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Activity is stored locally for demo traceability"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnClearActivity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Clear Mobile Activity"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D97706" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="22dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Supported Warehouse Actions"
                android:textColor="#061B3A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Assigned picking task verification"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Product barcode scan by phone camera"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Product and location inventory check"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Stock movement IN / OUT / ADJUSTMENT"
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B42318"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>