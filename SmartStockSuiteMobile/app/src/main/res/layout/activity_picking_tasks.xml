<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Picking Task"
            android:textColor="#061B3A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp" />

        <TextView
            android:id="@+id/tvTaskNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task 1 of 3"
            android:textColor="#667085"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/taskCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="24dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Assigned Task"
                android:textColor="#061B3A"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PT-1001"
                android:textColor="#0B5FFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product name"
                android:textColor="#061B3A"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="#667085"
                android:textSize="15sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quantity: 1"
                android:textColor="#667085"
                android:textSize="15sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvExpectedBarcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Expected barcode: -"
                android:textColor="#0B5FFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mobile_card"
            android:padding="24dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for scan"
                android:textColor="#667085"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan product barcode or enter it manually."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnScanProduct"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Scan Product Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0B5FFF" />

            <TextView
                android:id="@+id/tvManualLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Or enter barcode manually"
                android:textColor="#667085"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etManualBarcode"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Enter barcode"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#061B3A"
                android:textColorHint="#98A2B3"
                android:background="#FFFFFF" />

            <Button
                android:id="@+id/btnCheckManualBarcode"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Check Barcode"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#087443"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnGetNextTask"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Get Next Task"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D97706"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Back Home"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#667085"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>