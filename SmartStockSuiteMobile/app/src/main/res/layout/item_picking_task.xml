<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/taskItemCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_mobile_card"
    android:padding="18dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/tvItemTaskId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PT-1001"
        android:textColor="#061B3A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvItemProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product: iPad Air"
        android:textColor="#667085"
        android:textSize="14sp"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/tvItemLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Location: Aisle A / Rack 2"
        android:textColor="#667085"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvItemQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quantity to pick: 1"
        android:textColor="#667085"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvItemStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Pending"
        android:textColor="#0B5FFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

</LinearLayout>